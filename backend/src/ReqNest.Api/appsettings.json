{
  "ConnectionStrings": {
    "ReqNest": ""
  },
  "Storage": {
    "ConnectionString": "",
    "ServiceUri": null,
    "DefaultContainer": "requirements",
    "MarkDevelopmentUploadsClean": false
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Database": {
    "MigrateOnStartup": false
  },
  "Notifications": {
    "RunDeadlineWorker": true,
    "RunEmailWorker": true
  },
  "Reports": {
    "RunScheduleWorker": true
  },
  "Integrations": {
    "RunWebhookWorker": true,
    "RunConnectionWorker": true
  },
  "Authentication": {
    "RateLimit": {
      "PermitLimit": 30,
      "WindowSeconds": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
