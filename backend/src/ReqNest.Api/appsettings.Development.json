{
  "ConnectionStrings": {
    "ReqNest": "Host=localhost;Port=5432;Database=reqnest;Username=reqnest;Password=reqnest_dev_password"
  },
  "Storage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ServiceUri": null,
    "DefaultContainer": "requirements",
    "MarkDevelopmentUploadsClean": true
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "Database": {
    "MigrateOnStartup": true
  },
  "Notifications": {
    "RunDeadlineWorker": true,
    "RunEmailWorker": true
  },
  "Reports": {
    "RunScheduleWorker": true
  },
  "Integrations": {
    "RunWebhookWorker": true,
    "RunConnectionWorker": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
