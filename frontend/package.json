{
  "name": "reqnest",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "postinstall": "npm run primeui:license",
    "prestart": "npm run primeui:license",
    "start": "ng serve --proxy-config proxy.conf.json",
    "prebuild": "npm run primeui:license",
    "build": "ng build",
    "prewatch": "npm run primeui:license",
    "watch": "ng build --watch --configuration development",
    "pretest": "npm run primeui:license",
    "primeui:license": "node tools/generate-primeui-license.mjs",
    "test": "ng test",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": "24.18.x",
    "npm": "11.16.x"
  },
  "dependencies": {
    "@angular/cdk": "^22.0.4",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@primeuix/themes": "^3.0.0-rc.1",
    "marked": "^18.0.6",
    "primeng": "^22.0.0-rc.2",
    "quill": "2.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "10.0.1",
    "angular-eslint": "22.0.0",
    "axe-core": "4.12.1",
    "eslint": "10.6.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.63.0",
    "vitest": "^4.0.8"
  }
}
